#!/bin/bash
gmt gmtset FONT_ANNOT_PRIMARY=12p,Helvetica
gmt gmtset MAP_FRAME_TYPE plain
gmt gmtset MAP_FRAME_PEN thicker,black
gmt gmtset PS_MEDIA=a2
gmt gmtset FORMAT_GEO_MAP=ddd
#################################

home=/Users/tnye/Library/CloudStorage/OneDrive-DOI/UO-projects/ONC-EEW

# Input variables
batch=$1
peak_slip=$2
Mw=$3
rupt_name=$4
run_num=$5
lon=$6
lat=$7
inc=$8
scale=$9

# Map extent
LONMIN=-129
LONMAX=-121.75 # Longitude range of plots
LATMIN=39.5
LATMAX=51.5 # Latitude range of plotslots
REGION=-R${LONMIN}/${LONMAX}/${LATMIN}/${LATMAX}
SCALE=2i
BOUNDS="-BWesN -B2p"

# In files
slab2=/Users/tnye/slab_models/Cascadia/cas_slab2_dep_02.24.18.grd
DEM=${home}/GMT/topo/cascadia30.grd
ruptures_path=${home}/GMT/plotting_files
rupt_epi=${ruptures_path}/rupture_epi/${batch}/${rupt_name}_epi.txt
rupt_xy=${ruptures_path}/rupture_xy/${batch}/${rupt_name}.xy
oncew_coords=${home}/GMT/data/station_info/onc-ew_coords.txt
shakealert_coords=${home}/GMT/data/station_info/shakealert_coords.txt
overlap_coords=${home}/GMT/data/station_info/overlap_coords.txt
epic_grid_kml=/Users/tnye/GoogleEarth/EPIC_detection_grid.kml
epic_grid_txt=/Users/tnye/GoogleEarth/EPIC_detection_grid.txt
topo_no=${home}/GMT/topo/topo_no.grd
topo=${home}/GMT/topo/topo.grad
slip_cpt=${home}/GMT/cpt/slip.cpt
topo_cpt=${home}/GMT/cpt/topo.cpt
bathy_cpt=${home}/GMT/cpt/bathy.cpt

# Out files
Mlabel=${home}/GMT/plotting_files/Mlabel.txt

# Out file name
out=cascadia-$run_num

#################################

# Convert kml to txt
gmt kml2gmt $epic_grid_kml -V > $epic_grid_txt

# Cpt
gmt makecpt -C/Users/tnye/cpt/magma_white.cpt -I -T0/$scale/0.02 -Z > $slip_cpt
gmt makecpt -C/Users/tnye/cpt/gray_lt.cpt -T-0.65/0.65/0.01 -Z -V0 > $topo_cpt
gmt makecpt -C/Users/tnye/cpt/gr58_hult.cpt -T-5000/0/1 -Z -I -V0 > $bathy_cpt

# Make map
gmt psbasemap $REGION -JM$SCALE $BOUNDS -K > $out.eps

#topo/bathy
gmt grdimage $topo -R -J -C$topo_cpt -K -O >> $out.eps
gmt pscoast -S197/212/253 -Di -W0/0/0,0.25p -R -J -K -O >> $out.eps
# gmt pscoast -Q -R -J -O >> $out.eps
# gmt pscoast -Gc -Di -R -J -O >> $out.eps
#

# gmt pscoast -Q -R -J -K -O >> $out.eps
#
# # Now plot the triangles
gmt psxy $rupt_xy -R -J -L -C$slip_cpt -K -O >> $out.eps
gmt psxy $rupt_xy -R -J -W0.01p,180/180/180 -K -O >> $out.eps

#Draw coastline
gmt pscoast $REGION -J $BOUNDS -A2 -Df -N2/0.2p -N1/0.2p -W0.2p -Lf-96.7/14.9/15/100k+u -K -O >> $out.eps

# Plot epicenter
gmt psxy $rupt_epi -R$range -J$J -Dj0.08[0.06] -Sa0.45c -W.5p,black -B -K -O >> ${out}.eps

# Plot stations
gmt psxy $oncew_coords -R$range -J$J -St0.18c -G142/83/201 -Wblack -K -O >> ${out}.eps
gmt psxy $shakealert_coords -R$range -J$J -St0.18c -G54/156/110 -Wblack -K -O >> ${out}.eps
gmt psxy $overlap_coords -R$range -J$J -St0.18c -G227/194/64 -Wblack -K -O >> ${out}.eps

# Plot detection grids
gmt psxy $epic_grid_txt -R -J -W1.25p,54/156/110 -K -O >> ${out}.eps
gmt psxy -R -J -W1.25p,142/83/201 -K -O >> ${out}.eps << BOXEND
-132.75 46
-122 46
-122 52
-132.75 52
BOXEND

gmt psscale -C$slip_cpt -D0.9i/-0.2i/1.6i/0.12ih -B$inc:"Slip(m)": --FONT_LABEL=12p,Helvetica,black -K -O  >> $out.eps

# Add Magnitude
echo -127.7 40.0 M${Mw} > $Mlabel
gmt pstext $Mlabel -R -J -F+f14p,black -N -O  >> $out.eps

# cat > $legend << END

# S 0i i 0.2c 54/156/110 0.25p 0.3i Stations used for EPIC tests
# S 0.1i i 0.2c 142/83/201 0.25p 0.3i Stations used for ONC-EW tests
# S 0.1i i 0.2c 5227/194/64 0.25p 0.3i Stations used for both tests
# V 0 1p
# N 1
# END
#
# gmt pslegend -Dg-129/40.25+w1.5i/1i -R -J -F+p+gwhite $legend -O >> $out.eps


#Convert to raster and move
echo converting to raster
gmt psconvert $out.eps -Tg -A -P
echo cleaning up
rm $out.eps
mv $out.png /Users/tnye/Library/CloudStorage/OneDrive-DOI/UO-projects/ONC-EEW/manuscript/figures/rupture_models/test_ruptures/png/${out}.png
